# ─── .env.example ───────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Neo4j ────────────────────────────────────────────────────────────────────
# Local:  bolt://localhost:7687
# Cloud:  neo4j+s://<hostname>:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Local: host=localhost, port=6333
# Cloud: host=<cluster>.cloud.qdrant.io, port=6333, api_key=<key>
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=          # uncomment for Qdrant Cloud

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings ───────────────────────────────────────────────────────────────
# Use one of:
#   all-MiniLM-L6-v2               → EMBEDDING_DIM=384  (fast)
#   nomic-ai/nomic-embed-text-v1.5 → EMBEDDING_DIM=768  (higher quality)
GROQ_EMBED_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
SEMANTIC_THRESHOLD=0.75

# ── Retrieval ────────────────────────────────────────────────────────────────
RRF_K=60

# ── CAG ──────────────────────────────────────────────────────────────────────
CAG_CONTEXT_LIMIT=6000
CAG_MIN_ACCESS_COUNT=5
